PRIVATE_KEY=
NETWORK=testnet                        # testnet | mainnet
# API_BASE_URL=https://demoapi.dipcoin.io  # optional REST override
# CUSTOM_RPC=                              # optional Sui fullnode override
# DEMO_SYMBOL=BTC-PERP

# ---- Bank / orders / margin ----
RUN_DEPOSIT=0
RUN_WITHDRAW=0
RUN_MARKET_ORDER=0
RUN_LIMIT_ORDER=0
RUN_CANCEL_ORDER=0
RUN_ADJUST_LEVERAGE=0
RUN_MARGIN_ADD=0
RUN_MARGIN_REMOVE=0
RUN_TPSL_DEMO=0
RUN_TPSL_EDIT=0

# ---- Vault: REST snapshot ----
RUN_VAULT_REST=1
# Target vault id; if empty the demo falls back to creator -> holdings -> list.
# VAULT_ID=0xb6fde87bc12395b9e61a174dc7e9b7e2ee4eff5d45645822c8db320c799b52a1

# ---- Vault: creator lifecycle ----
# Provision a new vault (consumes vaultCreatingFee + initialDeposit USDC).
RUN_VAULT_CREATE=0
VAULT_NAME=sdk-demo-vault
# Defaults to the wallet address when unset.
# VAULT_TRADER=
VAULT_MAX_CAP=100000
VAULT_MIN_DEPOSIT=10
VAULT_PROFIT_SHARE=0.2
VAULT_CREATOR_MIN_RATIO=0.05
VAULT_INITIAL_DEPOSIT=100

# ---- Vault: creator settings (each independently gated) ----
# Toggle public deposit acceptance (true = accept follower deposits, false = pause).
RUN_VAULT_SET_DEPOSIT_STATUS=0
VAULT_DEPOSIT_STATUS=true

# Adjust the vault total cap (must be >= current followerMaxCap).
RUN_VAULT_SET_MAX_CAP=0

# Adjust the minimum deposit amount.
RUN_VAULT_SET_MIN_DEPOSIT=0

# Adjust the per-follower holding cap (<= maxCap).
RUN_VAULT_SET_FOLLOWER_MAX_CAP=0
VAULT_FOLLOWER_MAX_CAP=10000

# Toggle the "auto-close vault on follower withdraw" flag.
RUN_VAULT_SET_AUTO_CLOSE=0
VAULT_AUTO_CLOSE_ON_WITHDRAW=false

# Change the trader address; defaults to the wallet address.
RUN_VAULT_SET_TRADER=0
# VAULT_NEW_TRADER=

# Update the vault description (REST only, no on-chain tx).
RUN_VAULT_UPDATE_DESCRIPTION=0
VAULT_DESCRIPTION=Updated via SDK demo

# ---- Vault: follower flows ----
# Follower deposit.
RUN_VAULT_DEPOSIT=0
VAULT_DEPOSIT_AMOUNT=10

# Follower withdraw: amount in USDC, converted to shares using navps.
RUN_VAULT_WITHDRAW=0
VAULT_WITHDRAW_AMOUNT=1
# Set to 1 to redeem the entire balance, ignoring VAULT_WITHDRAW_AMOUNT.
VAULT_WITHDRAW_MAX=0
# Set to 1 to bypass the client-side lock-period guard. The on-chain call will
# still abort with MoveAbort 2038 if the lock period has not elapsed.
VAULT_WITHDRAW_SKIP_LOCK=0

# Followers claim residual USDC after the vault has been closed.
RUN_VAULT_CLAIM_CLOSED=0

# ---- Vault: operator / destructive ----
# Operator / creator settles pending withdrawal requests (request IDs required).
RUN_VAULT_FILL_WITHDRAW=0
# Comma-separated, e.g. 0xabc,0xdef
# VAULT_WITHDRAW_REQUEST_IDS=

# Creator closes the vault (irreversible; run last).
RUN_VAULT_CLOSE=0

# Remove the on-chain vault record after it has been closed and drained.
RUN_VAULT_REMOVE=0

# ---- Vault: creator/trader trades on behalf of the vault (parentAddress flow) ----
# Mirrors `selectedAccount` in ts-frontend/src/pages/perp.
# Every flag below uses VAULT_ID as parentAddress.

# Read the vault's account info / positions / open orders (REST GET).
RUN_VAULT_PERP_SNAPSHOT=0

# Set the vault's preferred leverage.
RUN_VAULT_PERP_SET_LEVERAGE=0
VAULT_PERP_TARGET_LEVERAGE=10
VAULT_PERP_MARGIN_TYPE=ISOLATED

# Vault MARKET / LIMIT order.
RUN_VAULT_PERP_MARKET_ORDER=0
VAULT_PERP_MARKET_SIDE=BUY
VAULT_PERP_MARKET_QTY=0.001
VAULT_PERP_MARKET_LEVERAGE=10

RUN_VAULT_PERP_LIMIT_ORDER=0
VAULT_PERP_LIMIT_SIDE=BUY
VAULT_PERP_LIMIT_QTY=0.001
VAULT_PERP_LIMIT_PRICE=75000
VAULT_PERP_LIMIT_LEVERAGE=10

# Cancel the vault's first open order.
RUN_VAULT_PERP_CANCEL=0

# Add / remove isolated margin (on-chain).
RUN_VAULT_PERP_ADD_MARGIN=0
VAULT_PERP_MARGIN_ADD=100
RUN_VAULT_PERP_REMOVE_MARGIN=0
VAULT_PERP_MARGIN_REMOVE=10

# reduceOnly market order to close. Defaults to the current position quantity
# when VAULT_PERP_CLOSE_QTY is not set.
RUN_VAULT_PERP_CLOSE_POSITION=0
# VAULT_PERP_CLOSE_QTY=
# VAULT_PERP_SYMBOL=BTC-PERP
